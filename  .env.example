# NOVA AGI (orquestador) — ejemplo

# Server
PORT=8080

# Auth (hocker.one -> nova.agi)
# Usa NOVA_ORCHESTRATOR_KEY (recomendado) o ORCHESTRATOR_KEY
NOVA_ORCHESTRATOR_KEY=__PON_AQUI_UN_TOKEN_LARGO_MIN_16__

# Supabase (SERVICE ROLE)
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__SUPABASE_SERVICE_ROLE_KEY__

# Firma HMAC para commands (DEBE ser el mismo que hocker.one y el Node Agent)
COMMAND_HMAC_SECRET=__LONG_RANDOM_SECRET__

# OpenAI
OPENAI_API_KEY=__OPENAI__
OPENAI_MODEL=gpt-5
# Opcionales
OPENAI_MODEL_FAST=gpt-5-mini
OPENAI_MODEL_PRO=gpt-5

# Gemini
GEMINI_API_KEY=__GEMINI__
GEMINI_MODEL=gemini-2.0-flash
# Opcionales
GEMINI_MODEL_FAST=gemini-2.0-flash
GEMINI_MODEL_PRO=gemini-2.0-pro

# Budgets (opcional)
BUDGETS_ENABLED=false
BUDGET_OPENAI_TOKENS=250000
BUDGET_GEMINI_TOKENS=250000

# Actions (seguro)
ACTIONS_ENABLED=true
ACTIONS_NEED_APPROVAL=true
DEFAULT_NODE_ID=hocker-node-1
ACTIONS_REQUIRE_HEADER=true