# Server
PORT=8080
NODE_ENV=production

# Auth: hocker.one -> nova.agi
NOVA_ORCHESTRATOR_KEY=__SET_ME__

# Supabase (SERVICE ROLE)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__SET_ME__

# Default project
DEFAULT_PROJECT_ID=global

# Providers
OPENAI_API_KEY=__SET_ME__
GEMINI_API_KEY=__SET_ME__

# Models (no te cases con nombres)
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_PRO=gpt-4o
GEMINI_MODEL_FAST=gemini-1.5-flash
GEMINI_MODEL_PRO=gemini-1.5-pro

# Router / Budgets (tokens por mes)
ROUTER_ENABLE_BUDGETS=1
BUDGET_MONTHLY_OPENAI_TOKENS=200000
BUDGET_MONTHLY_GEMINI_TOKENS=400000

# Actions (opcional): crear events / encolar commands
ACTIONS_ENABLED=0
ACTIONS_REQUIRE_HEADER=1