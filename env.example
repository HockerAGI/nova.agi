PORT=8080
NODE_ENV=production
CORS_ORIGIN=*

NOVA_ORCHESTRATOR_KEY=replace_with_a_long_secret_key
COMMAND_HMAC_SECRET=replace_with_a_second_secret_key

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

HOCKER_ONE_URL=https://hocker.one
HOCKER_ONE_API_URL=https://api.hocker.one

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_PRO=gpt-4o

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_FAST=gemini-2.0-flash
GEMINI_MODEL_PRO=gemini-2.0-pro

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_MODEL_FAST=claude-3-5-haiku-latest
ANTHROPIC_MODEL_PRO=claude-3-5-sonnet-latest

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OLLAMA_MODEL_FAST=llama3.1
OLLAMA_MODEL_PRO=llama3.1

ACTIONS_ENABLED=true
ACTIONS_NEED_APPROVAL=true
ACTIONS_REQUIRE_HEADER=true
DEFAULT_NODE_ID=hocker-node-1
FALLBACK_NODE_ID=hocker-fabric
PROJECT_DEFAULT_ID=hocker-one
MAX_MEMORY_MESSAGES=12
REQUEST_TIMEOUT_MS=30000
LOG_LEVEL=info