# ==========================================
# NOVA AGI - ORQUESTADOR CENTRAL
# ==========================================
PORT=8080
# Llave secreta para que Hocker One se conecte con NOVA
NOVA_ORCHESTRATOR_KEY=tu_super_secreto_de_mas_de_16_caracteres

# ==========================================
# HOCKERCHAIN (BASE DE DATOS)
# ==========================================
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...tu_llave_service_role

# ==========================================
# VERTX SECURITY (CERO CONFIANZA)
# ==========================================
# Debe ser EXACTAMENTE LA MISMA que pusiste en el proyecto hocker.one
COMMAND_HMAC_SECRET=tu_secreto_criptografico_generado_para_firmas

# ==========================================
# SYNTIA MEMORY (OBSERVABILIDAD LLMOps)
# ==========================================
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ==========================================
# MODELOS COGNITIVOS (LLMs)
# ==========================================
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_PRO=gemini-2.0-pro-exp-02-05

# ==========================================
# CONFIGURACIÓN OPERATIVA
# ==========================================
ACTIONS_ENABLED=true
ACTIONS_NEED_APPROVAL=true
# Nodo virtual por defecto en Hocker Automation Fabric
DEFAULT_NODE_ID=hocker-fabric