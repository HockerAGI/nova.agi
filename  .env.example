# NOVA AGI ORCHESTRATOR
PORT=8787
NOVA_ORCHESTRATOR_KEY=__PON_AQUI_UN_TOKEN_LARGO__

# Providers (elige 1 o ambos)
OPENAI_API_KEY=__OPENAI__
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=__GEMINI__
GEMINI_MODEL=gemini-1.5-flash

# Supabase
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__SERVICE_ROLE__

# Firma comandos (DEBE ser el mismo que en hocker.one + agente)
COMMAND_HMAC_SECRET=__LONG_RANDOM_SECRET__

# Defaults
HOCKER_PROJECT_ID=global
HOCKER_DEFAULT_NODE_ID=hocker-node-1

# Actions
ACTIONS_ENABLED=true
ACTIONS_REQUIRE_HEADER=true